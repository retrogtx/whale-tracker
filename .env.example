# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and loaded by both the CLI bot and the dashboard.

# --- Bitcoin whale feed (no key needed; real on-chain data) ---
# A transaction is flagged as a whale when its USD value is >= this.
WHALE_THRESHOLD_USD=1000000

# How often to poll, in milliseconds.
POLL_INTERVAL_MS=15000

# How many recent txs / API calls to keep in memory.
MAX_EVENTS=200

# Optional: override the Bitcoin data source base URL.
# BTC_API_BASE=https://blockchain.info

# Optional: CryptoPanic token to add an aggregated news/social feed (incl. Twitter/X posts).
# Free token at https://cryptopanic.com/developers/api/
# CRYPTOPANIC_TOKEN=

# --- Whop copy-trade ---
# Used only to price/execute mirrored swaps. Tracking works without it.
WHOP_API_KEY=

# Compute copy-trade signals + real Whop quotes for each whale (default on when a key is set).
COPY_TRADE=true

# Actually EXECUTE swaps with real funds. Leave false unless you mean it.
COPY_TRADE_LIVE=false

# USD size of each mirrored buy, and the token pair to swap.
COPY_TRADE_BUDGET_USD=100
COPY_FROM_TOKEN=USDT
COPY_TO_TOKEN=cbBTC

# Trading account (biz_.../user_...) — required only for live execution.
# Leave blank to auto-detect from the API key on startup.
# WHOP_ACCOUNT_ID=

# Optional: override the Whop API base URL (e.g. the sandbox).
# WHOP_BASE_URL=https://sandbox-api.whop.com/api/v1
